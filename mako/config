# Soho Dusk Theme
max-visible=10
layer=overlay
font=CaskaydiaMono Nerd Font 10
background-color=#1a1721ee
text-color=#d0cbd8
border-color=#e89bc1
border-size=2
border-radius=8
max-icon-size=48
default-timeout=8000
anchor=top-right
margin=20
padding=12
width=350

# Grouped notifications
group-by=app-name
max-history=50

# Urgency levels
[urgency=low]
border-color=#7cc9a0
background-color=#1a1721ee

[urgency=normal]
border-color=#e89bc1
background-color=#1a1721ee

[urgency=critical]
border-color=#e87b97
background-color=#e87b97dd
default-timeout=0
